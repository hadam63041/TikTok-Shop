# Copy to .env and fill in what you have. Every key is optional —
# missing keys leave that connector in simulation mode.

# --- Agent brain ---
# Which brain the agent roster (and dashboard console) uses:
#   anthropic  → ANTHROPIC_API_KEY (default)
#   openai     → OPENAI_API_KEY (+ OPENAI_MODEL)
#   hermes     → your VPS Hermes platform's OAuth brain over its WebSocket
#                (HERMES_URL / HERMES_USERNAME / HERMES_PASSWORD) — no key here.
AGENT_BACKEND=anthropic

# Hermes bridge (used when AGENT_BACKEND=hermes). The platform supports only
# username/password auth, so the bridge logs in with a Hermes account; use a
# rotated credential. The 🛰️ Codex menu agent always uses this, regardless of
# AGENT_BACKEND, when these are set.
HERMES_URL=
HERMES_USERNAME=
HERMES_PASSWORD=

# Anthropic brain (used when AGENT_BACKEND=anthropic). Get one at
# https://platform.claude.com/
ANTHROPIC_API_KEY=

# OpenAI / Codex brain (used when AGENT_BACKEND=openai). OPENAI_MODEL defaults to
# gpt-5; set it to a Codex model if your account uses one.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5

# Where to persist state.json. In Docker, point this at a mounted volume so data
# survives container rebuilds, e.g. STATE_FILE=/data/state.json
STATE_FILE=

# --- External agent (VPS-hosted, already linked to OpenAI Codex) ---
# Link the dashboard to a third-party agent running in Docker on a VPS. That
# agent is already wired to OpenAI Codex on its side, so DO NOT put an OpenAI
# key here — Codex is reached through the VPS. Only the VPS endpoint and its own
# bearer token are needed. Use an https:// (TLS) URL.
VPS_AGENT_URL=
VPS_AGENT_KEY=

# --- Research data sources ---
# Google Trends works with NO key (live US trending searches).
# SerpApi unlocks real interest-over-time sparklines + Google Shopping /
# Amazon / eBay competitors with prices. One key, many marketplaces.
# Get one at https://serpapi.com/
SERPAPI_KEY=

# --- Business connectors: feed APIs here as you onboard each service ---
# ETSY_API_KEY also powers real Etsy competitor data in the Research tab.
ETSY_API_KEY=
ETSY_SHOP_ID=
PRINTIFY_API_TOKEN=
FIVERR_API_KEY=

# --- Dropship suppliers (ZenDrop + CJ Dropshipping tab) ---
ZENDROP_API_KEY=
# CJ Dropshipping OpenAPI. CJ_MCP_TOKEN can be the same API key used by the
# separate CJ MCP server endpoint.
CJ_API_KEY=
CJ_MCP_TOKEN=

# --- Marketplace sales channels (the "list to" targets) ---
# TikTok Shop Partner app (https://partner.tiktokshop.com/). App key + secret
# link the channel; publishing live also needs per-shop OAuth authorization
# (an access token) — distinct from TIKTOK_ADS_TOKEN below.
TIKTOK_SHOP_APP_KEY=
TIKTOK_SHOP_APP_SECRET=
# Optional: your app's service_id (Partner Center → app → Authorization) — set it
# to show a one-click "Authorize on TikTok Shop" link in the dashboard.
TIKTOK_SHOP_SERVICE_ID=

# Generative models
MIDJOURNEY_API_KEY=
HIGGSFIELD_API_KEY=
# Optional direct Higgsfield image-generation endpoint. If blank, Hermes keeps
# the weekly POD pipeline testable with a local generated design asset.
HIGGSFIELD_API_URL=
# Preferred path for weekly POD image generation: installed Higgsfield CLI.
HIGGSFIELD_CLI_PATH=
HIGGSFIELD_IMAGE_MODEL=nano_banana_2
HIGGSFIELD_WAIT_TIMEOUT=20m
HIGGSFIELD_WAIT_INTERVAL=5s
RUNWAY_API_KEY=
STABILITY_API_KEY=

# Ad platforms
META_ADS_TOKEN=
GOOGLE_ADS_TOKEN=
TIKTOK_ADS_TOKEN=

# Weekly POD automation. Auto-publish creates customer-visible Etsy listings
# through Printify; leave false until you intentionally want unattended publish.
POD_AUTOMATION_ENABLED=false
POD_AUTOMATION_INTERVAL_DAYS=7
POD_AUTOMATION_MAX_DESIGNS=3
POD_AUTOPUBLISH=false

# Server
PORT=8787
