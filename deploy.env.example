# Copy to deploy.env and fill in. docker compose reads these automatically.
# (In the Hostinger panel you can instead paste these into the env fields.)
# Everything here is OPTIONAL — the dashboard runs without any of it.

# Brain — OPTION A: a direct OpenAI API key (simple, but you said you use OAuth).
# Leave BLANK if you'll use your Hermes platform's OAuth brain instead (Option B).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5

# Brain — OPTION B: route through your Hermes platform (it holds the OpenAI OAuth).
# Filled in once we wire the bridge — your Hermes URL + a scoped pairing token
# (NOT your admin password).
HERMES_URL=
HERMES_PAIRING_TOKEN=

# MCP — lets your Hermes agent call this dashboard's business tools (Printify,
# research, listing, etc.) with its OAuth brain. Set a long random secret; you'll
# give the same value to Hermes when you add the MCP server. Tools are live
# actions (incl. publishing) so DO set a token. Generate one with:
#   openssl rand -hex 24
MCP_TOKEN=

# Optional business connectors (real data when set; simulation when blank).
SERPAPI_KEY=
PRINTIFY_API_TOKEN=
ZENDROP_API_KEY=
