# Copy to deploy.env and fill in. docker compose reads these automatically.
# (In the Hostinger panel you can instead paste these into the env fields.)
# Everything here is OPTIONAL — the dashboard runs without any of it.

# Brain — OPTION A: a direct OpenAI API key (simple, but you said you use OAuth).
# Leave BLANK if you'll use your Hermes platform's OAuth brain instead (Option B).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5

# Brain — OPTION B (recommended for you): route through your Hermes platform,
# which holds the OpenAI OAuth. No OpenAI key needed. To use this, set:
#   AGENT_BACKEND=hermes
# and fill these in (the platform only supports username/password auth, so the
# bridge logs in with a Hermes account — use a rotated credential):
AGENT_BACKEND=hermes
HERMES_URL=https://hermes-agent-b6y5.srv1753238.hstgr.cloud
HERMES_USERNAME=
HERMES_PASSWORD=

# MCP — lets your Hermes agent call this dashboard's business tools (Printify,
# research, listing, etc.) with its OAuth brain. Set a long random secret; you'll
# give the same value to Hermes when you add the MCP server. Tools are live
# actions (incl. publishing) so DO set a token. Generate one with:
#   openssl rand -hex 24
MCP_TOKEN=

# Optional business connectors (real data when set; simulation when blank).
SERPAPI_KEY=
PRINTIFY_API_TOKEN=
ZENDROP_API_KEY=
# CJ Dropshipping OpenAPI + optional MCP token for the CJ MCP endpoint.
CJ_API_KEY=
CJ_MCP_TOKEN=
# TikTok Shop channel (App Key + Secret; live publish also needs shop OAuth).
TIKTOK_SHOP_APP_KEY=
TIKTOK_SHOP_APP_SECRET=
TIKTOK_SHOP_SERVICE_ID=

# Weekly POD automation. POD_AUTOPUBLISH=true creates customer-visible Etsy
# listings through Printify after each scheduled research/design run.
POD_AUTOMATION_ENABLED=false
POD_AUTOMATION_INTERVAL_DAYS=7
POD_AUTOMATION_MAX_DESIGNS=3
POD_AUTOPUBLISH=false
HIGGSFIELD_API_URL=
HIGGSFIELD_CLI_PATH=
HIGGSFIELD_IMAGE_MODEL=nano_banana_2
HIGGSFIELD_WAIT_TIMEOUT=20m
HIGGSFIELD_WAIT_INTERVAL=5s
